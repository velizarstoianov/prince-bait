# LLM Provider
LLM_PROVIDER=claude
LLM_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Gmail OAuth2
GMAIL_USER_ID=me
CREDENTIALS_JSON_PATH=credentials.json
TOKEN_PICKLE_PATH=token.pickle

# Database (SQLAlchemy — runs light on SQLite locally, scales to Postgres in prod)
DATABASE_URL=sqlite:///princebait.db
# Production example:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/princebait

# Identity generation
IDENTITY_MODE=fake          # real | fake | ask
IDENTITY_LOCALE=en_US       # en_US | fr_FR | es_ES | it_IT | de_DE | pt_PT | nl_NL | pl_PL

# ── Mail connection ──
# Encryption key for stored mail credentials (REQUIRED for secrets to survive restart).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAIL_ENCRYPTION_KEY=

# OAuth redirect behavior for mail SSO
OAUTH_REDIRECT_MODE=loopback        # loopback (local dev) | web (deployed)
OAUTH_BASE_URL=                     # web mode only; callback = {OAUTH_BASE_URL}/oauth/callback

# Google OAuth (Gmail SSO) — set these OR reuse CREDENTIALS_JSON_PATH above
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft OAuth (Outlook / M365 SSO via IMAP/SMTP XOAUTH2)
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=      # optional for public-client / device-code
MICROSOFT_OAUTH_TENANT=common       # common | organizations | consumers | <tenant-id>

# App
APP_PORT=8000
APP_HOST=0.0.0.0
