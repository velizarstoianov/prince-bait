# LLM Provider
LLM_PROVIDER=claude
LLM_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Gmail OAuth2
GMAIL_USER_ID=me
CREDENTIALS_JSON_PATH=credentials.json
TOKEN_PICKLE_PATH=token.pickle

# Database (SQLAlchemy — runs light on SQLite locally, scales to Postgres in prod)
DATABASE_URL=sqlite:///scambaiter.db
# Production example:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/scambaiter

# Identity generation
IDENTITY_MODE=fake          # real | fake | ask
IDENTITY_LOCALE=en_US       # en_US | fr_FR | es_ES | it_IT | de_DE | pt_PT | nl_NL | pl_PL

# App
APP_PORT=8000
APP_HOST=0.0.0.0
